PORT=3000
NODE_ENV=development

# Database（本机 MySQL 用下面即可；连虚拟机/远程 MySQL 见下方说明）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=home_manager

# ----- 若从 Windows 连虚拟机里的 MySQL，请改为：-----
# DB_HOST=虚拟机的IP（例如 192.168.186.139）
# DB_USER=home_manager
# DB_PASSWORD=在虚拟机 MySQL 里为 home_manager 设置的密码
# 并在虚拟机 MySQL 中执行：
#   CREATE USER 'home_manager'@'%' IDENTIFIED BY '你的密码';
#   GRANT ALL PRIVILEGES ON home_manager.* TO 'home_manager'@'%'; FLUSH PRIVILEGES;

# Auth
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=./uploads
